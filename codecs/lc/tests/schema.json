            ]
          },
          {
            "type": "object",
            "properties": {
              "size": {
                "$ref": "#/$defs/LcElemSize"
              },
              "id": {
                "type": "string",
                "const": "HCLOG"
              }
            },
            "additionalProperties": false,
            "required": [
              "id",
