                "$ref": "#/$defs/LcElemSize"
              },
              "id": {
                "type": "string",
                "const": "DIFF"
              }
            },
            "additionalProperties": false,
            "required": [
              "id",
              "size"
            ]
          },
          {
            "type": "object",
            "properties": {
              "size": {
                "$ref": "#/$defs/LcElemSize"
              },
              "id": {
                "type": "string",
                "const": "DIFFMS"
              }
            },
            "additionalProperties": false,
            "required": [
              "id",
              "size"
            ]
          },
          {
            "type": "object",
            "properties": {
              "size": {
                "$ref": "#/$defs/LcElemSize"
              },
              "id": {
                "type": "string",
