            ]
          },
          {
            "type": "object",
            "properties": {
              "size": {
                "$ref": "#/$defs/LcElemSize"
              },
              "id": {
                "type": "string",
                "const": "BIT"
              }
            },
            "additionalProperties": false,
            "required": [
              "id",
              "size"
            ]
          },
          {
            "type": "object",
            "properties": {
              "size": {
                "$ref": "#/$defs/LcTupleSize"
              },
              "id": {
                "type": "string",
                "const": "TUPL"
              }
            },
            "additionalProperties": false,
            "required": [
